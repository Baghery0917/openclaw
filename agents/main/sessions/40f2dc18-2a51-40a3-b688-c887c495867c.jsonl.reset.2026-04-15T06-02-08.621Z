_history.append({\n+ 65             'timestamp': datetime.now().isoformat(),\n+ 66             'query': query,\n+ 67             'dimension': dimension,\n+ 68             'mode': 'mock'\n+ 69         })\n+ 70         \n+ 71         # 根据维度返回不同的模拟数据\n+ 72         mock_data = {\n+ 73             'technology': [\n+ 74                 {'title': f'{query} - 技术分析', 'url': 'https://example.com/tech', 'snippet': '拥有自研深度学习框架，GitHub开源项目获得高星'},\n+ 75                 {'title': f'{query} - 专利信息', 'url': 'https://patent.example.com', 'snippet': '拥有多项AI相关发明专利，技术壁垒明显'}\n+ 76             ],\n+ 77             'growth': [\n+ 78                 {'title': f'{query} - 财务数据', 'url': 'https://investor.example.com', 'snippet': '2023年ARR增长45%，用户规模快速扩大'},\n+ 79                 {'title': f'{query} - 用户增长', 'url': 'https://analytics.example.com', 'snippet': 'MAU季度环比增长25%，留存率高于行业平均'}\n+ 80             ],\n+ 81             'cost': [\n+ 82                 {'title': f'{query} - 成本结构', 'url': 'https://finance.example.com', 'snippet': '推理成本占收入35%，通过优化降低15%'},\n+ 83                 {'title': f'{query} - 毛利率', 'url': 'https://analysis.example.com', 'snippet': '毛利率68%，研发投入占比40%'}\n+ 84             ],\n+ 85             'competition': [\n+ 86                 {'title': f'{query} - 竞争分析', 'url': 'https://market.example.com', 'snippet': '在细分市场占有率30%，差异化优势明显'},\n+ 87                 {'title': f'{query} - 竞争格局', 'url': 'https://industry.example.com', 'snippet': '面临巨头竞争，但有独家功能护城河'}\n+ 88             ],\n+ 89             'team': [\n+ 90                 {'title': f'{query} - 团队背景', 'url': 'https://team.example.com', 'snippet': '创始人斯坦福博士，团队博士占比40%'},\n+ 91                 {'title': f'{query} - 人才结构', 'url': 'https://careers.example.com', 'snippet': '研发人员占比60%，工程经验丰富'}\n+ 92             ]\n+ 93         }\n+ 94         \n+ 95         return mock_data.get(dimension, mock_data['technology'])\n+ 96     \n+ 97     def _web_search(self, query: str, dimension: str = None) -> List[Dict[str, Any]]:\n+ 98         \"\"\"调用Open
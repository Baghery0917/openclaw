      \"\"\"提取用户增长信息\"\"\"\n+405         growth_keywords = ['用户增长', 'MAU', '月活跃用户', '季度增长', '同比增长']\n+406         \n+407         for result in search_results:\n+408             snippet = result.get('snippet', '')\n+409             if any(keyword in snippet for keyword in growth_keywords):\n+410                 # 提取百分比\n+411                 import re\n+412                 percentages = re.findall(r'\\d+[\\.\\d]*%', snippet)\n+413                 if percentages:\n+414                     return f\"用户增长率为{percentages[0]}\"\n+415                 else:\n+416                     return \"用户增长态势良好，具体数据需核实\"\n+417         \n+418         return \"用户增长信息需要进一步调查\"\n+419     \n+420     def _get_mock_growth_info(self) -> List[Dict]:\n+421         \"\"\"获取模拟增长信息\"\"\"\n+422         return [\n 328             {\n 329                 'aspect': 'ARR',\n 330                 'info': '2023年ARR为1.2亿美元，同比增长45%',\n 331                 'source': '公司财报',\n     ...\n 357                 'reliability': 'C',\n 358                 'date': '2024-01-20'\n 359             }\n 360         ]\n-361         \n-362         self.research_results['dimensions']['growth']['info'] = growth_info\n-363         return {'count': len(growth_info), 'items': growth_info}\n 364     \n 365     def collect_cost_info(self) -> Dict:\n 366         \"\"\"收集成本维度信息\n 367         \n     ...","firstChangedLine":327},"isError":false,"timestamp":1776144091498}}

urn {\n+149             'total_searches': len(self.search_history),\n+150             'modes_used': list(set([h['mode'] for h in self.search_history])),\n+151             'history': self.search_history\n+152         }\n+153 \n+154 \n  24 class ResearchCollector:\n  25     def __init__(self, company_name: str, company_data: Dict = None):\n  26         \"\"\"初始化信息收集器\n  27         \n     ...","firstChangedLine":24},"isError":false,"timestamp":1776143874623}}
